#!/bin/sh

# Ensure Xcode Command Line Tools are installed (required by Homebrew)
if ! xcode-select -p >/dev/null 2>&1; then
  xcode-select --install
  echo "Xcode Command Line Tools installing — re-run 'chezmoi apply' once it finishes."
  exit 1
fi

# Install homebrew if it doesn't exist yet
if [ -z "$(which brew)" ]; then
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  echo 'eval "$(/opt/homebrew/bin/brew shellenv)"' >> $HOME/.zprofile
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi

# Shared CLI packages
brew install \
  zsh \
  tmux \
  fzf \
  ripgrep \
  fd \
  eza \
  bat \
  jq \
  git-delta \
  wget \
  btop \
  git \
  git-flow \
  yt-dlp \
  mise \
  zoxide \
  gh \
  neovim \
  starship \
  forgit

{{ if not .is_snyk -}}
# Extras on personal devices
brew install \
  atuin \
  libyaml \
  syncthing

# Restart syncthing
brew services restart syncthing
{{ end -}}

# Install casks
{{ if .install_casks -}}
brew install \
  ghostty \
  1password \
  1password-cli \
  rectangle-pro \
  cursor

{{ if not .is_snyk -}}
# Personal-only casks
brew install \
  firefox \
  spotify \
  fantastical \
  mimestream \
  obsidian \
  discord \
  alfred \
  keyboard-maestro
{{ end -}}
{{ end -}}

# Desktop-specific packages (brew, casks, fonts, mas apps)
{{ if .is_desktop -}}
brew install \
  linearmouse \
  betterdisplay
{{ end -}}

# Install fonts
brew install font-iosevka-nerd-font font-iosevka-term-nerd-font

# Antidote for zsh
[ -d "${ZDOTDIR:-$HOME}/.antidote" ] || git clone --depth=1 https://github.com/mattmc3/antidote.git "${ZDOTDIR:-$HOME}/.antidote"

# Mise setup
mise install

# Mac App Store apps (personal devices only)
{{ if not .is_snyk -}}
brew install mas
mas install 1435957248    # Drafts
mas install 1475387142    # Tailscale
mas install 1542143627    # Omnifocus
mas install 1136220934    # Infuse
{{ end -}}

# fzf shell completion/keybindings setup
/opt/homebrew/opt/fzf/install --all --no-bash --no-fish

{{ if not .is_snyk -}}
# Atuin setup
atuin login
atuin sync
{{ end -}}

# Claude code setup
command -v claude >/dev/null 2>&1 || curl -fsSL https://claude.ai/install.sh | bash

echo ""
echo "============================================"
echo " Next steps:"
echo "============================================"
echo "  - Sign in to 1Password (desktop app)"
echo "  - Enable 1Password SSH agent in app settings"
echo "  - Run: gh auth login"
echo "  - Run: claude /login"
echo "  - Run: atuin login && atuin sync"
echo "  - Set up Syncthing pairing if needed"
echo "  - Restart terminal for PATH changes to take effect"
echo "============================================"
