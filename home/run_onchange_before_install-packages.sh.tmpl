#!/bin/sh

# Install homebrew if it doesn't exist yet
if [ -z "$(which brew)" ]; then
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  echo 'eval "$(/opt/homebrew/bin/brew shellenv)"' >> $HOME/.zprofile
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi

# Shared CLI packages
brew install \
  zsh \
  tmux \
  fzf \
  ripgrep \
  fd \
  eza \
  wget \
  btop \
  git \
  git-flow \
  yt-dlp \
  mise \
  zoxide \
  gh \
  neovim \
  starship \
  forgit

{{ if not .is_snyk -}}
# Extras on personal devices
brew install \
  atuin \
  libyaml \
  syncthing

# Restart syncthing
brew services restart syncthing
{{ end -}}

# Install casks
{{ if .install_casks -}}
brew install \
  ghostty \
  1password \
  1password-cli \
  rectangle-pro \
  cursor

{{ if not .is_snyk -}}
# Personal-only casks
brew install \
  firefox \
  spotify \
  fantastical \
  mimestream \
  obsidian \
  discord \
  alfred \
  keyboard-maestro
{{ end -}}
{{ end -}}

# Desktop-specific packages (brew, casks, fonts, mas apps)
{{ if .is_desktop -}}
brew install \
  linearmouse \
  betterdisplay
{{ end -}}

# Install fonts
brew install font-iosevka-nerd-font font-iosevka-term-nerd-font

# Antidote for zsh
git clone --depth=1 https://github.com/mattmc3/antidote.git ${ZDOTDIR:-~}/.antidote

# Install TPM for tmux
git clone https://github.com/tmux-plugins/tpm ~/.tmux/plugins/tpm

# Mise setup
mise install

# Mac App Store apps (personal devices only)
{{ if not .is_snyk -}}
brew install mas
mas install 1435957248    # Drafts
mas install 1475387142    # Tailscale
mas install 1542143627    # Omnifocus
mas install 1136220934    # Infuse
{{ end -}}

# fzf shell completion/keybindings setup
/opt/homebrew/opt/fzf/install --all --no-bash --no-fish

{{ if not .is_snyk -}}
# Atuin setup
atuin login
atuin sync
{{ end -}}

# Claude code setup
curl -fsSL https://claude.ai/install.sh | bash
