// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "proxy": "",
  "bottom_dock_layout": "contained",
  "tabs": {
    "file_icons": true,
    "git_status": false
  },
  "tab_bar": {
    "show_tab_bar_buttons": false,
    "show_nav_history_buttons": true,
    "show": true
  },
  "title_bar": {
    "show_menus": false,
    "show_user_picture": true,
    "show_user_menu": false,
    "show_sign_in": false,
    "show_branch_status_icon": true
  },
  "status_bar": {
    "show_active_file": false,
    "active_language_button": true
  },
  "file_finder": {
    "file_icons": true
  },
  "inlay_hints": {
    "enabled": true
  },
  "tab_size": 2,
  "toolbar": {
    "quick_actions": false,
    "breadcrumbs": false
  },
  "sticky_scroll": {
    "enabled": true
  },
  "which_key": {
    "delay_ms": 200,
    "enabled": true
  },
  "session": {
    "trust_all_worktrees": true
  },
  "cli_default_open_behavior": "new_window",
  "project_panel": {
    "hide_hidden": false,
    "hide_root": false,
    "git_status_indicator": true,
    "scrollbar": {
      "horizontal_scroll": true,
      "show": "never"
    },
    "indent_size": 20.0,
    "entry_spacing": "comfortable",
    "hide_gitignore": false,
    "button": true,
    "dock": "left"
  },
  "outline_panel": {
    "button": true,
    "dock": "right"
  },
  "collaboration_panel": {
    "dock": "right"
  },
  "agent": {
    "show_turn_stats": true,
    "sidebar_side": "right",
    "dock": "right",
    "favorite_models": [],
    "model_parameters": []
  },
  "git_panel": {
    "show_count_badge": false,
    "diff_stats": true,
    "folder_icons": false,
    "file_icons": true,
    "status_style": "icon",
    "default_width": 300.0,
    "dock": "right"
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "agent_servers": {
    "codex-acp": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    }
  },
  "auto_install_extensions": {
    "astro": true,
    "catpuccin-icons": true,
    "color-highlight": true,
    "html": true,
    "zedokai": true
  },
  "icon_theme": "Catppuccin Mocha",
  "buffer_font_family": "Iosevka Nerd Font Propo",
  "ui_font_family": ".ZedSans",
  "ui_font_size": 14.0,
  "buffer_font_size": 13.0,
  "theme": "Zedokai Darker (Filter Spectrum)"
}
