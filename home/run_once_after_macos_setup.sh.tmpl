#!/bin/sh

{{ if not .is_snyk -}}
# Hostname
HOSTNAME_TARGET="{{ .hostname }}"
if [ -n "$HOSTNAME_TARGET" ] && [ "$(scutil --get ComputerName 2>/dev/null)" != "$HOSTNAME_TARGET" ]; then
  sudo scutil --set HostName "$HOSTNAME_TARGET"
  sudo scutil --set LocalHostName "$HOSTNAME_TARGET"
  sudo scutil --set ComputerName "$HOSTNAME_TARGET"
  dscacheutil -flushcache
  echo "Hostname set to $HOSTNAME_TARGET."
fi
{{ end -}}

# Keyboard: fast key repeat + enable repeat on hold
defaults write NSGlobalDomain InitialKeyRepeat -int 15
defaults write NSGlobalDomain KeyRepeat -int 2
defaults write NSGlobalDomain ApplePressAndHoldEnabled -bool false

# Trackpad: tap to click
defaults write com.apple.driver.AppleBluetoothMultitouch.trackpad Clicking -bool true
defaults write com.apple.AppleMultitouchTrackpad Clicking -bool true
defaults -currentHost write NSGlobalDomain com.apple.mouse.tapBehavior -int 1
defaults write NSGlobalDomain com.apple.mouse.tapBehavior -int 1

# Finder: default to list view, search current folder
defaults write com.apple.finder FXPreferredViewStyle -string "Nlsv"
defaults write com.apple.finder FXDefaultSearchScope -string "SCcf"

# Screenshots: save to ~/Documents/sync/screenshots
mkdir -p "$HOME/Documents/sync/screenshots"
defaults write com.apple.screencapture location -string "$HOME/Documents/sync/screenshots"

killall Finder SystemUIServer 2>/dev/null

echo "This script will:"
echo "  - Remove all icons from the dock"
echo "  - Hide recent apps in the dock"
echo ""
printf "Do you want to proceed? [y/N] "
read -r response

if [ "$response" = "y" ] || [ "$response" = "Y" ]; then
    # Remove all icons from the dock
    defaults write com.apple.dock persistent-apps -array

    # Hide recent apps in the dock
    defaults write com.apple.dock show-recents -bool false

    # Kill the dock so that it refreshes
    killall Dock

    echo "Dock configuration updated."
else
    echo "Skipped dock configuration."
fi
